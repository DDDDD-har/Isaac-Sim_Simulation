                prepend string inputs:qosProfile.connect = </World/Robots/WheelLoader/ROS2_OdomAndTF/ros2_qos_profile.outputs:qosProfile>
                custom uint64 inputs:queueSize
                custom bool inputs:staticPublisher = 0
