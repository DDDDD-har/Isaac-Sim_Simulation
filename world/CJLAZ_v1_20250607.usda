    def "map1" (
        active = true
        prepend payload = @./usd/CZG/map1.usdc@
    )
    {
        quatf xformOp:orient = (1, 0, 0, 0)
        float3 xformOp:scale = (1, 1, 1.5)
        double3 xformOp:translate = (0, 0, -1.7690772688880125)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

        over "_materials" (
            active = true
        )
        {
            over "material_0_001" (
                delete apiSchemas = ["PhysxDeformableBodyMaterialAPI"]
                prepend apiSchemas = ["PhysicsMaterialAPI"]
            )
            {
                float physics:dynamicFriction = 1
                float physics:staticFriction = 1

                over "Principled_BSDF"
                {
                    float inputs:clearcoat = 1
                    float inputs:clearcoatRoughness = 0
                    color3f inputs:diffuseColor = (0.23723556, 0.28185326, 0.2535022)
                    float inputs:displacement = 0
                    float inputs:ior = 5
                    float inputs:opacityThreshold = 0
                }
            }
        }

        over "env_light" (
            active = false
        )
        {
            token visibility = "inherited"
        }

        over "simple_002"
        {
            over "simple_002" (
                prepend apiSchemas = ["MaterialBindingAPI", "PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsCollisionAPI", "PhysxCollisionAPI", "PhysxConvexHullCollisionAPI", "PhysicsMeshCollisionAPI", "PhysxTriangleMeshCollisionAPI", "PhysxConvexDecompositionCollisionAPI", "PhysxTriangleMeshSimplificationCollisionAPI", "PhysxSDFMeshCollisionAPI"]
            )
            {
                rel material:binding = </World/map1/_materials/material_0_001> (
                    bindMaterialAs = "weakerThanDescendants"
                )
                uniform token physics:approximation = "sdf"
                bool physics:collisionEnabled = 1
                bool physics:kinematicEnabled = 0
                bool physics:rigidBodyEnabled = 1
                int physxRigidBody:lockedPosAxis = 7
                int physxRigidBody:lockedRotAxis = 7
                quatf xformOp:orient = (1, 0, 0, 0)
                float3 xformOp:scale = (1, 1, 1)
                double3 xformOp:translate = (0, 0, -0.3485672129779389)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
            }
        }
    }
